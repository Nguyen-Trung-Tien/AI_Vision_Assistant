# ──────────────────────────────────────────────
# Admin Dashboard — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Backend API URL (proxied qua Vite dev server)
VITE_API_BASE_URL=/api

# Backend origin — dùng cho Vite proxy target
VITE_BACKEND_URL=http://127.0.0.1:3000

# WebSocket URL — cho Socket.IO connection
VITE_WS_URL=http://127.0.0.1:3000

# Dashboard dev server
VITE_PORT=4200

# App metadata
VITE_APP_TITLE=AI Vision Assistant — Admin Dashboard
VITE_APP_VERSION=1.9.4

# React Query settings (ms)
VITE_QUERY_STALE_TIME=30000
VITE_QUERY_CACHE_TIME=300000

# Feature flags
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_MOCK_DATA=false
